{
  "$schema": "https://www.schemastore.org/tsconfig",

  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": [
      "ESNext",
      "ESNext.Array",
      "ESNext.Collection",
      "ESNext.Error",
      "ESNext.Iterator",
      "ESNext.Promise"
    ],

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
